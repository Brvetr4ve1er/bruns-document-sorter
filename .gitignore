# =============================================================================
#  BRUNs .gitignore
# =============================================================================
#  Rule of thumb: ignore everything that gets generated, downloaded, or that
#  embeds machine-specific paths. NEVER use broad globs (`*.html`, `*.csv`)
#  because they silently exclude application source or fixtures.
#
#  Use a leading `/` to anchor paths to the repo root so a rule like `/data/`
#  only ignores the top-level data folder, NOT `core/data/` or `modules/data/`.
# =============================================================================

# --- Python build/cache ------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
/build/
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
/var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments (NOT shipped — recipient runs install.sh) ----------
/.venv/
/venv/
/ENV/
/env/
/python/

# --- Native binaries (Tesseract bundle — too big for git, downloaded by installer)
#     Only ignore at root level so a hypothetical core/utils/myutil.exe is still tracked.
/tesseract_bin/*.exe
/tesseract_bin/*.dll
/tesseract_bin/*.dylib

# --- Tesseract OCR data (downloaded by INSTALL.bat — see install_tesseract.bat)
/tessdata/
/tesseract_bin/
/models/

# --- Tesseract bundled documentation (bundled with the Tesseract binary,
#     not part of our source). Listed explicitly instead of `*.html` because
#     Jinja templates in core/api/templates/ ARE part of our source.
/tesseract_bin/*.html
ambiguous_words.1.html
classifier_tester.1.html
cntraining.1.html
combine_lang_model.1.html
combine_tessdata.1.html
dawg2wordlist.1.html
lstmeval.1.html
lstmtraining.1.html
merge_unicharsets.1.html
mftraining.1.html
set_unicharset_properties.1.html
shapeclustering.1.html
tesseract.1.html
text2image.1.html
unicharambigs.5.html
unicharset.5.html
unicharset_extractor.1.html
wordlist2dawg.1.html

# --- Runtime data (databases, uploads, logs — machine-specific) --------------
#     Anchored to root so `core/storage/` or `modules/*/db/` are never silently ignored.
/data/
/db/
*.log
*.sqlite3
*.sqlite3-journal
*.sqlite3-shm
*.sqlite3-wal

# --- Generated exports (operator-edited XLSX / CSV outputs) ------------------
/data/exports/
/trial files to process/

# --- Test output data (generated by test runs, not source) -------------------
tests/data/export_*/
tests/data/*.zip
tests/data/*.db

# --- IDE / editor / AI tooling -----------------------------------------------
.vscode/
.idea/
.claude/
.gemini/
.streamlit/config.toml
.streamlit/secrets.toml
.pytest_cache/

# --- OS-specific noise -------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store

# --- PyInstaller intermediates -----------------------------------------------
*.spec

# --- Backups -----------------------------------------------------------------
*.bak

# --- Portable bundle output --------------------------------------------------
/dist/
/BRUNs-Portable/
/BRUNs-Portable.zip
